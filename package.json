{
  "name": "verdant-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "森林風格元件庫（@verdant/ui）與示範網頁 monorepo — 電商站、旅館預約站、元件展示廊",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev:gallery": "npm -w examples/gallery run dev",
    "dev:sales": "npm -w examples/sales-web run dev",
    "dev:booking": "npm -w examples/booking-web run dev",
    "dev:portfolio": "npm -w examples/portfolio-web run dev",
    "build:gallery": "npm -w examples/gallery run build",
    "build:sales": "npm -w examples/sales-web run build",
    "build:booking": "npm -w examples/booking-web run build",
    "build:portfolio": "npm -w examples/portfolio-web run build",
    "build": "npm run build:gallery && npm run build:sales && npm run build:booking && npm run build:portfolio"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.0"
  }
}
